{
  "name": "specifico",
  "version": "0.4.1",
  "description": "SPEC-driven development system for Claude Code",
  "license": "MIT",
  "homepage": "https://specifico.dev",
  "bugs": {
    "url": "https://github.com/cjgaliana/specifico/issues"
  },
  "keywords": [
    "spec-driven",
    "claude-code",
    "development-workflow",
    "git",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjgaliana/specifico.git"
  },
  "bin": {
    "specifico": "bin/install.js"
  },
  "files": [
    "bin/",
    "template/"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=template/cli.js && cp template/cli.js .claude/commands/specifico/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0"
  }
}
